*.pid

# ---- Data (generated) ----
# Snapshots are cached API responses used for offline/degraded runs.
# Keep the directory but ignore large captured payloads by default.
data/snapshots/*.json
!data/snapshots/.gitkeep
data/quality-report.json

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
*.swp
