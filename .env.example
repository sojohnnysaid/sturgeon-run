# ==========================================================================
# Sturgeon Run — environment configuration
# Copy to `.env` and adjust. NEVER commit a real .env (see .gitignore).
# ==========================================================================

# ---- PostGIS ----
POSTGRES_USER=sturgeon
POSTGRES_PASSWORD=change-me-in-dev
POSTGRES_DB=sturgeon
POSTGRES_HOST=postgis
POSTGRES_PORT=5432
# Full URL used by services (host resolves via the compose network).
DATABASE_URL=postgres://sturgeon:change-me-in-dev@postgis:5432/sturgeon

# ---- Ingest ----
# Bounding polygon for the Hudson estuary (roughly NY Harbor -> Troy).
# min_lon, min_lat, max_lon, max_lat
HUDSON_BBOX=-74.10,40.55,-73.60,42.75
GBIF_TAXON_NAME=Acipenser oxyrinchus
# Comma-separated USGS site numbers along the Hudson (instantaneous values).
# Empty = auto-discover active IV stations inside HUDSON_BBOX.
USGS_SITES=
# Set to 1 to load from data/snapshots/ instead of hitting live APIs.
USE_SNAPSHOT=0
# Set to 1 to persist fetched live responses into data/snapshots/.
WRITE_SNAPSHOT=1

# ---- corridor-api (Rust) ----
CORRIDOR_API_BIND=0.0.0.0:8080
CORRIDOR_API_URL=http://corridor-api:8080
RUST_LOG=info,corridor_api=debug
# Corridor derivation: hex grid cell edge length in meters.
CORRIDOR_HEX_METERS=2000

# ---- tiles (Martin) ----
MARTIN_PORT=3000

# ---- mcp (TypeScript / Node) ----
MCP_PORT=8081
# Bearer token required to call the MCP endpoint. If UNSET/empty the MCP
# HTTP endpoint is DISABLED and returns 503 (fail-closed).
MCP_API_TOKEN=

# ---- web (React / Vite) ----
WEB_PORT=5173
# The Vite dev server proxies /api and /tiles to these targets, so the browser
# only ever talks to the web origin (no CORS). In compose these are the
# in-network service hostnames; for local `npm run dev` use localhost.
VITE_PROXY_API_TARGET=http://corridor-api:8080
VITE_PROXY_TILES_TARGET=http://tiles:3000
